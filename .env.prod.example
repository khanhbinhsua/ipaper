# ============================================
#  CẤU HÌNH PRODUCTION — sao chép thành .env.prod rồi sửa giá trị
#  cp .env.prod.example .env.prod && nano .env.prod
# ============================================

# ----- Tên miền (đổi theo domain của anh) -----
APP_DOMAIN=ipaper.congty.vn
STORAGE_DOMAIN=storage.ipaper.congty.vn

# ----- Backend -----
NODE_ENV=production
PORT=3000
TZ=UTC
FRONTEND_URL=https://ipaper.congty.vn

# ----- PostgreSQL (nội bộ trong Docker) -----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ipaper
DB_USER=ipaper
DB_PASS=ĐỔI_MẬT_KHẨU_MẠNH_Ở_ĐÂY

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379

# ----- JWT (BẮT BUỘC đổi — chuỗi ngẫu nhiên dài) -----
JWT_SECRET=ĐỔI_THÀNH_CHUỖI_NGẪU_NHIÊN_DÀI_64_KÝ_TỰ
JWT_EXPIRES_IN=8h

# ----- MinIO (lưu file) -----
# Nội bộ: backend upload/download qua hostname container
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_USER=minioadmin
MINIO_PASS=ĐỔI_MẬT_KHẨU_MINIO_MẠNH
MINIO_BUCKET=ipaper-files
# Công khai: dùng để ký link tải/xem file (trình duyệt truy cập qua Caddy SSL)
MINIO_PUBLIC_ENDPOINT=storage.ipaper.congty.vn
MINIO_PUBLIC_PORT=443
MINIO_PUBLIC_USE_SSL=true

# ----- SMTP (email thông báo — tùy chọn, để trống nếu chưa dùng) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=iPaper <noreply@ipaper.congty.vn>
