# ============================================
#  CẤU HÌNH PRODUCTION — sao chép thành .env.prod rồi sửa giá trị
#  cp .env.prod.example .env.prod && nano .env.prod
# ============================================

# ----- Tên miền (đổi theo domain của anh) -----
APP_DOMAIN=ipaper.vitaliahmd.com

# ----- Backend -----
NODE_ENV=production
PORT=3000
TZ=UTC
# Lần deploy ĐẦU TIÊN đặt true để tự tạo bảng. Sau khi chạy OK nên đổi về false.
DB_SYNC=true
FRONTEND_URL=https://ipaper.vitaliahmd.com

# ----- PostgreSQL — DÙNG TÊN CONTAINER riêng (tránh trùng tên "postgres" với project khác cùng mạng) -----
DB_HOST=ipaper_postgres
DB_PORT=5432
DB_NAME=ipaper
DB_USER=ipaper
DB_PASS=ĐỔI_MẬT_KHẨU_MẠNH_Ở_ĐÂY

# ----- Redis -----
REDIS_HOST=ipaper_redis
REDIS_PORT=6379

# ----- JWT (BẮT BUỘC đổi — chuỗi ngẫu nhiên dài) -----
JWT_SECRET=ĐỔI_THÀNH_CHUỖI_NGẪU_NHIÊN_DÀI_64_KÝ_TỰ
JWT_EXPIRES_IN=8h

# ----- MinIO (lưu file) -----
# Alias gạch NGANG (MinIO không chấp nhận gạch dưới trong hostname; tránh trùng "minio")
MINIO_ENDPOINT=ipaper-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_USER=minioadmin
MINIO_PASS=ĐỔI_MẬT_KHẨU_MINIO_MẠNH
MINIO_BUCKET=ipaper-files
# Công khai: link tải/xem file đi qua chính domain app (path /ipaper-files/...)
# nginx sẽ proxy /ipaper-files/ -> minio. Chỉ cần 1 domain + 1 cert.
MINIO_PUBLIC_ENDPOINT=ipaper.vitaliahmd.com
MINIO_PUBLIC_PORT=443
MINIO_PUBLIC_USE_SSL=true

# ----- SMTP (email thông báo — tùy chọn, để trống nếu chưa dùng) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=iPaper <noreply@ipaper.congty.vn>
